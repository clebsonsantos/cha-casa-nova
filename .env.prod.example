# Copie para .env.prod e preencha com os valores reais
# Nunca versione .env.prod no git!

# Postgres (container interno)
POSTGRES_DB=cha_casa_nova
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-por-senha-forte

# Auth
JWT_SECRET=troque-por-string-aleatoria-longa-32-chars-minimo

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cha-de-casa-nova
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# URL pública da aplicação (sem barra no final)
NEXT_PUBLIC_APP_URL=https://meu-dominio.com.br
